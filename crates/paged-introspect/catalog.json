{
  "hostFunctions": [
    {
      "name": "paged.set",
      "params": "(id, path, value)",
      "returns": "bool",
      "kind": "write",
      "summary": "Set a property (see settablePaths) on the addressed element. null clears."
    },
    {
      "name": "paged.get",
      "params": "(id, path)",
      "returns": "value | null",
      "kind": "read",
      "summary": "Read one property value of the addressed element."
    },
    {
      "name": "paged.insertText",
      "params": "(storyId, offset, text)",
      "returns": "bool",
      "kind": "author",
      "summary": "Insert plain text at a story body offset; \\n splits paragraphs."
    },
    {
      "name": "paged.deleteRange",
      "params": "(storyId, start, end)",
      "returns": "bool",
      "kind": "author",
      "summary": "Delete the [start, end) character range of a story."
    },
    {
      "name": "paged.insertTextFrame",
      "params": "(pageId, [t,l,b,r])",
      "returns": "bool",
      "kind": "author",
      "summary": "Create an empty text-pourable frame at page-local point bounds. Mints a story (id NOT returned — see constraints)."
    },
    {
      "name": "paged.insertFrame",
      "params": "(pageId, [t,l,b,r])",
      "returns": "bool",
      "kind": "author",
      "summary": "Create an empty graphic (non-text) frame; the usual placeImage target."
    },
    {
      "name": "paged.insertPage",
      "params": "(afterPageId?)",
      "returns": "bool",
      "kind": "author",
      "summary": "Append a page after afterPageId (or at the end), inheriting the default master."
    },
    {
      "name": "paged.placeImage",
      "params": "(frameId, uri, fit?)",
      "returns": "bool",
      "kind": "author",
      "summary": "Place an image into a frame; fit is an optional fitting mode."
    },
    {
      "name": "paged.applyStyle",
      "params": "(storyId, start, end, styleRef)",
      "returns": "bool",
      "kind": "author",
      "summary": "Apply a paragraph/character style to a story range. Scope inferred from the ref prefix (CharacterStyle/… else Paragraph)."
    },
    {
      "name": "paged.createGroup",
      "params": "([id, ...])",
      "returns": "bool",
      "kind": "author",
      "summary": "Group two-or-more elements; <2 valid members returns false."
    },
    {
      "name": "paged.undo",
      "params": "()",
      "returns": "bool",
      "kind": "history",
      "summary": "Undo the last mutation."
    },
    {
      "name": "paged.redo",
      "params": "()",
      "returns": "bool",
      "kind": "history",
      "summary": "Redo the last undone mutation."
    },
    {
      "name": "paged.inspect",
      "params": "(id)",
      "returns": "ElementProperties JSON",
      "kind": "read",
      "summary": "Full property snapshot for one element (or storyRange)."
    },
    {
      "name": "paged.tree",
      "params": "()",
      "returns": "SceneTreeNode[] JSON",
      "kind": "read",
      "summary": "Document hierarchy: spreads → pages → frames."
    },
    {
      "name": "paged.stories",
      "params": "()",
      "returns": "StorySummary[] JSON",
      "kind": "read",
      "summary": "Loaded stories with selfId + characterCount + paragraphCount. The source of valid story ids."
    },
    {
      "name": "paged.layers",
